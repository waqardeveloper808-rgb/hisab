# =========================================

# GULF HISAB - MASTER .GITIGNORE

# =========================================

# -----------------------------

# OS / SYSTEM FILES

# -----------------------------

.DS_Store
Thumbs.db
desktop.ini

# -----------------------------

# ENV / SECRETS

# -----------------------------

.env
.env.*
!.env.example

# -----------------------------

# LOGS

# -----------------------------

*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -----------------------------

# TEMP / CACHE

# -----------------------------

tmp/
temp/
.cache/
*.tmp

# -----------------------------

# ARTIFACTS / DEBUG OUTPUTS

# -----------------------------

artifacts/
qa_reports/
*.zip
*.tar
*.gz
*.rar
*.7z

# -----------------------------

# QA / TEST OUTPUTS (ONLY IF NOT USED IN CODE)

# -----------------------------

# Uncomment ONLY if qa is not used in runtime

# qa/

# -----------------------------

# NODE / FRONTEND

# -----------------------------

node_modules/
.next/
dist/
build/
out/
.vite/
coverage/

# -----------------------------

# VSCODE / IDE

# -----------------------------

.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# -----------------------------

# LARAVEL CORE

# -----------------------------

/vendor/
/bootstrap/cache/*
!/bootstrap/cache/.gitignore

/storage/*.key
/storage/debugbar/
/storage/logs/*
/storage/framework/cache/*
/storage/framework/sessions/*
/storage/framework/views/*
/storage/app/public/*
!/storage/app/public/.gitignore

# -----------------------------

# PUBLIC BUILDS

# -----------------------------

/public/build
/public/hot

# -----------------------------

# DATABASE

# -----------------------------

*.sqlite
*.sqlite3
*.db

# -----------------------------

# TESTING

# -----------------------------

.phpunit.result.cache

# -----------------------------

# DOCKER (IF USED)

# -----------------------------

docker-compose.override.yml

# -----------------------------

# NEXT.JS / REACT SPECIFIC

# -----------------------------

.next/
.vercel/

# -----------------------------

# TYPESCRIPT

# -----------------------------

*.tsbuildinfo

# -----------------------------

# BACKUPS / EXPORTS

# -----------------------------

*.bak
*.backup
*.old

# -----------------------------

# UPLOADS (OPTIONAL - DEPENDS ON STRATEGY)

# -----------------------------

# If storing user uploads locally, ignore:

# public/uploads/

# storage/uploads/

# -----------------------------

# SECURITY / CERTS

# -----------------------------

*.pem
*.key
*.crt

# -----------------------------

# MISC

# -----------------------------

*.swp
*.swo

# =========================================

# END

